POSTGRESQL_ADDON_HOST=
POSTGRESQL_ADDON_DB=
POSTGRESQL_ADDON_USER=
POSTGRESQL_ADDON_PORT=
POSTGRESQL_ADDON_PASSWORD=
POSTGRESQL_ADDON_URI=
DATABASE_URL=
# Prisma adds connection_limit=1 automatically — do not raise without a pooler
JWT_SECRET=change_me_to_a_long_random_secret
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_CONTACT_EMAIL=contact@yourdomain.com
# Optional custom Open Graph image (URL or path, e.g. /og-image.svg)
NEXT_PUBLIC_OG_IMAGE_URL=

# Google AdSense (add after approval)
NEXT_PUBLIC_GOOGLE_ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXX
NEXT_PUBLIC_GOOGLE_ADSENSE_SLOT=XXXXXXXXXX
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Meta Pixel (optional, for Meta ads / analytics)
NEXT_PUBLIC_META_PIXEL_ID=

